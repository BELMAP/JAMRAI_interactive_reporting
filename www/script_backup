Zoonoses_data_campylobacter <- read_csv2("data/Campylobacter_data.csv",
                                         na = c("", "NA"),
                                         trim_ws = TRUE
) %>%
  filter(!is.na(Sample_size)) %>%
  group_by(Year, Host, Pathogen,Indicator) %>%
  summarise(                       # combine CHU Liege and ULB data
